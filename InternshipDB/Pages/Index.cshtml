@page
@model InternshipDB.Pages.IndexModel

@{
    ViewData["Title"] = "Company Directory";
}

<section class="page-hero mb-4">
    <div>
        <h1>Internship Companies Database</h1>
    </div>
</section>

<form method="get" class="search-panel mb-4">
    <div class="search-grid">
        <div>
            <label asp-for="SearchString" class="form-label fw-semibold">Search</label>
            <input asp-for="SearchString" class="form-control form-control-lg search-input-compact"
                   placeholder="Search by company, sector or person..." />
        </div>
        <div>
            <label asp-for="SelectedSector" class="form-label fw-semibold">Sector</label>
            <select asp-for="SelectedSector" class="form-select form-select-lg">
                <option value="">All sectors</option>
                @foreach (var sector in Model.Sectors)
                {
                    <option value="@sector">@sector</option>
                }
            </select>
        </div>
        <div>
            <label asp-for="SortOrder" class="form-label fw-semibold">Sort</label>
            <select asp-for="SortOrder" class="form-select form-select-lg">
                <option value="az">A-Z</option>
                <option value="za">Z-A</option>
            </select>
        </div>
        <div class="search-tools">
            <div class="search-actions-vertical">
                <a asp-page="Create" class="btn btn-add-company btn-toolbar">Add Company</a>
                <div class="search-actions mt-2">
                    <a asp-page="/Index" class="btn btn-clear-action btn-toolbar">Clear</a>
                    <button type="submit" class="btn btn-search-action btn-toolbar ms-2">Search</button>
                </div>
            </div>
        </div>
    </div>
</form>

<table class="table company-table align-middle">
    <thead>
        <tr>
            <th>ID</th>
            <th>Company Name</th>
            <th class="one-line-field">Company Registration Number</th>
            <th>Sector</th>
            <th>Person in Charge</th>
            <th>Email Address</th>
            <th>Contact Number</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Company.Any())
        {
            @foreach (var item in Model.Company)
            {
                <tr class="company-row" data-id="@item.Id" style="cursor:pointer;" onclick="location.href='@Url.Page("./Details", new { id = item.Id })'">
                    <td data-label="ID" class="id-cell">
                        @item.Id
                    </td>
                    <td data-label="Company Name">
                        <div class="company-name" title="@item.CompanyName">@item.CompanyName</div>
                    </td>
                    <td data-label="Company Registration Number">
                        <div class="company-meta one-line-field">@(string.IsNullOrWhiteSpace(item.CompanyRegistrationNumber) ? "-" : item.CompanyRegistrationNumber)</div>
                    </td>
                    <td data-label="Sector">
                        <span class="sector-pill one-line" title="@item.Sector">@item.Sector</span>
                    </td>
                    <td data-label="Person in Charge">
                        <div class="company-meta" title="@item.PersonInCharge">@(string.IsNullOrWhiteSpace(item.PersonInCharge) ? "-" : item.PersonInCharge)</div>
                    </td>
                    <td data-label="Email Address">
                        @if (!string.IsNullOrWhiteSpace(item.Email))
                        {
                            <a class="contact-link" href="mailto:@item.Email" title="@item.Email">@item.Email</a>
                        }
                        else
                        {
                            <span class="company-meta">-</span>
                        }
                    </td>
                    <td data-label="Contact Number">
                        <div class="company-meta" title="@item.ContactNumber">@(string.IsNullOrWhiteSpace(item.ContactNumber) ? "-" : item.ContactNumber)</div>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="empty-state">No companies found for the current search.</td>
            </tr>
        }
    </tbody>
</table>

<div class="table-summary">
    <span>Total in database: <strong>@Model.TotalCompanies</strong></span>
</div>

@section Scripts {
    <script>
        (function () {
            const rows = document.querySelectorAll('.company-row');

            function hideAllActionRows() {
                document.querySelectorAll('.company-actions-row').forEach(r => r.style.display = 'none');
            }

            rows.forEach(r => {
                r.addEventListener('click', function (e) {
                    // ignore clicks on links inside the row (email links etc.)
                    if (e.target.closest('a')) return;

                    const actionsRow = r.nextElementSibling;
                    if (!actionsRow || !actionsRow.classList.contains('company-actions-row')) return;

                    // toggle this one, hide others
                    const isVisible = actionsRow.style.display !== 'none';
                    hideAllActionRows();
                    actionsRow.style.display = isVisible ? 'none' : 'table-row';
                });
            });

            // click outside to close
            document.addEventListener('click', function (e) {
                if (!e.target.closest('.company-row') && !e.target.closest('.company-actions-row')) {
                    hideAllActionRows();
                }
            });
        })();
    </script>
}
